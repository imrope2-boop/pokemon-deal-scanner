# Reddit API Credentials
# Get from: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=PokemonDealScanner/1.0 by YourUsername

# TCGPlayer API (optional - enhances pricing accuracy)
# Get from: https://developer.tcgplayer.com/
TCGPLAYER_PUBLIC_KEY=your_tcgplayer_public_key
TCGPLAYER_PRIVATE_KEY=your_tcgplayer_private_key

# Pokemon Price Tracker API (free tier: 100 credits/day)
# Get from: https://www.pokemonpricetracker.com/pokemon-card-price-api
POKEMON_PRICE_API_KEY=your_api_key_here

# App Settings
SCAN_INTERVAL_MINUTES=15
DASHBOARD_PORT=8080
SECRET_KEY=change_this_to_a_random_secret_key
